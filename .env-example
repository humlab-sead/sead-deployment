COMPOSE_PROJECT_NAME=sead
DOMAIN=localhost
CLIENT_RELEASE=latest
JAS_RELEASE=main
SBC_RELEASE=master

# Ports
WEB_PORT=80
MONGO_EXPRESS_PORT=8082
JAS_PORT=8484
POSTGRESQL_PORT=5432

#Normally "sead_production" or "sead_staging", but can be mapped to any database name available in the postgresql instance
DATABASE_NAME=sead_staging

#The password of the postgres user (root) in the postgresql instance
DATABASE_POSTGRES_PASSWORD=

# A PostgreSQL user, should preferably be read-only
DATABASE_USER=sead_master
DATABASE_PASSWORD=

DATABASE_READ_ONLY_USER=sead_ro
DATABASE_READ_ONLY_PASSWORD=

#PostgREST
PGRST_USER=postgrest
POSTGREST_DB_PASSWORD=
PGRST_HOST=postgresql
PGRST_DB_SCHEMA=postgrest_api
PGRST_DB_ANON_ROLE=postgrest_anon
PGRST_LOG_LEVEL=info
PGRST_SERVER_HOST=*
PGRST_SERVER_PORT=3001

#MongoDB
MONGODB_ROOT_USER=root
MONGODB_ROOT_PASSWORD=
MONGO_EXPRESS_USER=sead
MONGO_EXPRESS_PASSWORD=

#Sead Query API
QueryBuilderSetting__Store__Username=
QueryBuilderSetting__Store__Password=

# Redis
REDIS_VERSION=5-alpine
REDIS_HOST_PORT=6379:6379
REDIS_DATA_DIR=./database/redis
REDIS_CONF_FILE=./conf/redis/redis.conf
REDIS_PASSWORD=

# JSON API SERVER
JAS_API_PORT=8484
JAS_POSTGRES_HOST=postgresql
JAS_POSTGRES_PORT=5432
JAS_POSTGRES_DATABASE=sead_staging
JAS_POSTGRES_MAX_CONNECTIONS=10
JAS_MONGO_HOST=mongo
JAS_MONGO_DB=sead
JAS_CACHE_STORAGE_METHOD=mongo
JAS_MAX_CONCURRENT_FETCHES=5
JAS_USE_SITE_CACHE=true
JAS_USE_TAXA_CACHE=true
JAS_USE_ECOCODE_CACHE=true
JAS_USE_SINGLE_PERSISTENT_DBCON=false
JAS_USE_QUERY_CACHE=true
JAS_PROTECTED_ENDPOINTS_USER=sead
JAS_PROTECTED_ENDPOINTS_PASS=
JAS_SESSION_SECRET=
JAS_ARTIFICIAL_LATENCY_MS=0

#This is used for google sign-in when using viewstates

JAS_GOOGLE_CLIENT_ID=
JAS_GOOGLE_CLIENT_SECRET=

JAS_GITHUB_CLIENT_ID=
JAS_GITHUB_CLIENT_SECRET=

JAS_ORCID_CLIENT_ID=
JAS_ORCID_CLIENT_SECRET=
JAS_AUTH_SALT=

MARIA_DB_NAME=sead
MARIA_DB_ROOT_PASSWORD=
MARIA_DB_USER=sead
MARIA_DB_PASSWORD=

# MCP access mode: restricted | unrestricted
MCP_ACCESS_MODE=restricted

# postgres_mcp (custom HTTP MCP server) port and bearer token
MCP_PORT=4000
MCP_BEARER_TOKEN=

# Matomo settings - These are not actually ready by matomo (they are set during install via the web interface), but it's recommended to fill them out here for your own reference
MATOMO_SUPERUSER=
MATOMO_SUPERUSER_PASSWORD=

# Basic Auth for OpenRefine
HTACCESS_USER=sead
HTACCESS_PASSWORD=

# LLM settings (used by sead_authority_service)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_BASE_URL=http://localhost:11434
